<section id="create-cast">
    <div class="createCastSection">
        <div class="info-cast">
            <h2>"You're gonna need a bigger boat." — "Jaws," 1975.</h2>
        </div>

        <form method="POST" class="createCastForm">
            <h2>Add Actor</h2>
            <ul class="noBullet">
                <li>
                    <label for="name">Name:</label>
                    <input type="text" class="inputFields" id="name" name="name" value="{{actorsData.name}}" />
                </li>
                <li>
                    <label for="age">Age:</label>
                    <input type="number" class="inputFields" id="age" name="age" value="{{actorsData.age}}" />
                </li>
                <li>
                    <label for="born">Born:</label>
                    <input type="text" class="inputFields" id="born" name="born" value="{{actorsData.born}}" />
                </li>
                {{!-- <li>
                    <label for="name-in-movie">Name in Movie:</label>
                    <input type="text" class="inputFields" id="name-in-movie" name="nameInMovie" />
                </li> --}}
                <li>
                    <label for="image">Cast Image:</label>
                    <input type="text" class="inputFields" id="image" name="imgUrl" value="{{actorsData.imgUrl}}" />
                </li>
                <li id="center-btn">
                    <button id="create-btn">Add Cast</button>
                </li>
            </ul>
        </form>
    
        {{> genericError error=error }}

    </div>
</section>