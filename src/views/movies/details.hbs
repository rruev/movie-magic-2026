{{setTitle "Movie Details"}}
<section id="details-page">

    <div class="main_card">
        <div class="card_left">
            <div class="card_datails">

                <h1>{{movie.title}}</h1>
                <div class="card-movie">
                    <div class="first-info">
                        <p class="card-genre">Genre: {{movie.genre}}</p>
                        <p class="card-director">Directror: {{movie.director}}</p>
                    </div>
                    <div class="second-info">

                        <p class="card-year">Year: {{movie.year}}</p>
                        <p class="card-ranking">Rating: {{movie.rating}} <span id="stars">&#x2605; &#x2605; &#x2605;
                                &#x2605;</span></p>
                    </div>

                </div>

                <p class="disc">Description:{{movie.description}}</p>
                <p class="card-category">Category: {{movie.category}}</p>
            </div>
            {{#if isOwner}}
            <div class="details-btn">
                <a href="/movies/edit/{{movie.id}}" id="edit-button">Edit</a>
                <a href="/movies/delete/{{movie.id}}" id="delete-button">Delete</a>
                <a href="/movies/attach-actor/{{movie.id}}" id="attach-button" >Attach Actor</a>
            </div>
            {{/if}}
        </div>
        <div class="card_right">
            <img src="{{movie.imgUrl}}" alt="image">
        </div>
    </div>
    <div class="main-cast-card">
        {{#each movie.actors }}
        <div class="cast-card">
            <div class="card-img">
                <img src="{{actor.imgUrl}}" alt="{{actor.name}}">
            </div>
            <div class="cast-info">
                <h1>{{actor.name}}</h1>
                <h3>Age: {{actor.age}}</h3>
                <h3>Born: {{actor.born}}</h3>
                <h3>Name in Movie: {{nameInMovie}}</h3>
            </div>
        </div>
        {{else}}
        <p>No actors added yet...</p>
        {{/each}}
    </div>

</section>